# Tool-local state — not part of the product
.remember/
.superpowers/
.serena/
.direnv/
.claude/settings.local.json
.claude/scheduled_tasks.lock
.playwright-mcp/

# Secrets and env
.env
.env.*
.envrc
# placeholders carry no secrets and match scan's _ENV_SAFE_SUFFIXES carve-out
!.env.example
!.env.sample
!.env.template

# OS and editor cruft
.DS_Store
*.log
Thumbs.db

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/

# Generated dashboards (the tool's own output, when run on this repo)
.agent-context-center/
.ai-control-center/

# Node (if the generator gains a JS toolchain later)
node_modules/
dist/
build/
